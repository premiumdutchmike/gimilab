# OneGolf — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Direct PostgreSQL connection string (from Supabase dashboard → Settings → Database)
SUPABASE_DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Recurring price IDs from Stripe dashboard
STRIPE_CASUAL_PRICE_ID=price_...   # $99/mo — 100 credits
STRIPE_CORE_PRICE_ID=price_...     # $149/mo — 150 credits
STRIPE_HEAVY_PRICE_ID=price_...    # $199/mo — 210 credits

# ── AI (Anthropic) ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Upstash Redis ─────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=A...

# ── Upstash QStash (background jobs) ─────────────────────────────────────────
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=eyJ...

# ── Resend (email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=bookings@onegolf.app

# ── PostHog (product analytics) ───────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Random secret to authenticate Vercel Cron requests — generate with: openssl rand -base64 32
CRON_SECRET=replace-with-random-secret
